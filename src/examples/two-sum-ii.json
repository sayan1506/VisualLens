    },
    {
      "id": "s2",
      "template": "concept",
      "components": [
        {
          "type": "text",
          "props": {
            "text": "The array is sorted. Start one pointer at the smallest value and one at the largest, then move them inward based on how their sum compares to the target.",
            "size": "lg"
          }
        },
        {
          "type": "callout",
          "props": {
            "variant": "info",
            "text": "If the sum is too big, the largest value is too big → move R inward. If too small → move L inward."
          }
        }
      ],
      "narration": ""
    },
    {
      "id": "s3",
      "template": "code_walk",
      "components": [
        {
          "type": "code_panel",
          "props": {
            "title": "Two pointers",
            "activeLine": 2,
            "lines": [
              "left = 0, right = n - 1",
              "while left < right:",
              "  sum = nums[left] + nums[right]",
              "  if sum == target: return [left, right]",
              "  elif sum > target: right -= 1",
              "  else: left += 1"
            ]
          }
        },
        {
          "type": "array_block",
          "props": {
            "values": [2, 7, 11, 15],
            "highlighted": [0, 3],
            "pointers": [
